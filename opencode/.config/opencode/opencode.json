{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "model": "opencode-go/deepseek-v4-pro",
  "permission": {
    "bash": {
      "wt *": "allow"
    },
    "external_directory": {
      "~/projects/**": "allow"
    }
  },
  "agent": {
    "copilot": {
      "prompt": "{file:./prompts/copilot.md}",
      "description": "Agent tailored to integrate with codebase and workflow in quick and efficient manners",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "permission": {
        "bash": "deny"
      }
    }
  },
  "autoupdate": true,
  "default_agent": "build",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-1cf18f21-a0f8-46e6-8d74-dbfd508b4d44"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
